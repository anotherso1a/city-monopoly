/* Sidebar 组件样式 — 纸面风格, 沿用 Game 页面样式 */

.sidebar-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 600;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.sidebar-overlay.show {
  opacity: 1;
  visibility: visible;
}

.sidebar {
  position: fixed;
  top: 0;
  left: 0;
  width: 70%;
  max-width: 560rpx;
  height: 100%;
  background-color: #fff9ed;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(124, 88, 0, 0.04) 0%, transparent 40%),
    radial-gradient(circle at 80% 70%, rgba(124, 88, 0, 0.03) 0%, transparent 40%);
  box-shadow: 4rpx 0 24rpx rgba(124, 88, 0, 0.2);
  transform: translateX(-100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  box-sizing: border-box;
}

.sidebar.open {
  transform: translateX(0);
}

.sidebar-header {
  display: flex;
  align-items: center;
  padding: 48rpx 40rpx;
  margin: 32rpx;
  background-color: rgba(255, 255, 255, 0.5);
  transition: background-color 0.15s ease;
}
.sidebar-header:active,
.sidebar-header-active {
  background-color: rgba(247, 238, 210, 0.85);
}

.sidebar-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background-color: #f7eed2;
  flex-shrink: 0;
}

.sidebar-user {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.sidebar-nickname {
  font-weight: 700;
  color: #1f1c0b;
  margin-bottom: 4rpx;
}

.sidebar-level {
  color: #705a49;
  font-style: italic;
}

.sidebar-items {
  display: flex;
  flex-direction: column;
  padding: 0 32rpx 32rpx;
}

.sidebar-item {
  display: flex;
  align-items: center;
  padding: 28rpx 16rpx;
  color: #1f1c0b;
  font-weight: 500;
  border-bottom: 2rpx solid rgba(131, 117, 96, 0.15);
  transition: background-color 0.15s ease;
}

/* 最后一项不画底边 —— 避免列表底部出现一条孤立的横线 */
.sidebar-item:last-child {
  border-bottom: none;
}

.sidebar-item:active {
  background-color: rgba(247, 238, 210, 0.6);
}

.sidebar-item-danger {
  color: #b53a3a;
}

.sidebar-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  color: #705a49;
  width: 36rpx;
  text-align: center;
}

.sidebar-item-danger .sidebar-icon {
  color: #b53a3a;
}

