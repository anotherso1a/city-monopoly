/* drawing-progress 组件 - loading 状态展示 (骰子 + 文字 + 进度条) */

.centerpiece {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  /* max-width: 600rpx; */
}

.die-wrapper {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  margin-bottom: 40rpx;
  animation: hand-drawn-spin 1.5s infinite cubic-bezier(0.4, 0, 0.6, 1);
  transform-origin: 50% 50%;
  /* GPU 加速:提升为独立合成层,避免旋转动画重绘主线程 */
  will-change: transform;
  transform: translateZ(0);
}

.die-box {
  position: absolute;
  inset: 0;
  background-color: var(--primary-container, #ffb800);
  border-style: solid;
  border-width: 4rpx 3rpx 4rpx 4rpx;
  border-color: var(--on-primary-container, #6b4c00);
  border-radius: 6rpx 14rpx 6rpx 16rpx / 16rpx 6rpx 14rpx 6rpx;
  box-shadow: 6rpx 6rpx 0px 0px var(--shadow-color, rgba(0, 0, 0, 0.1));
  display: flex;
  align-items: center;
  justify-content: center;
}

.die-dots {
  display: grid;
  grid-template-columns: repeat(2, 12rpx);
  grid-template-rows: repeat(2, 12rpx);
  gap: 10rpx;
  justify-content: center;
  align-items: center;
  width: 34rpx;
  height: 34rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: var(--on-primary-container, #6b4c00);
}

.dot-hidden {
  visibility: hidden;
}

.dot-wide {
  grid-column: span 2;
  justify-self: center;
}

@keyframes hand-drawn-spin {
  0%   { transform: translateZ(0) rotate(0deg) scale(1); }
  25%  { transform: translateZ(0) rotate(90deg) scale(1.1) translateX(4rpx); }
  50%  { transform: translateZ(0) rotate(180deg) scale(1) translateY(-4rpx); }
  75%  { transform: translateZ(0) rotate(270deg) scale(1.1) translateX(-4rpx); }
  100% { transform: translateZ(0) rotate(360deg) scale(1); }
}

/* text-block: headline 循环 + subtitle 静态 */
.text-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-bottom: 16rpx;
}

.headline {
  font-size: 48rpx;
  line-height: 56rpx;
  font-weight: 700;
  color: var(--on-surface-variant, #514532);
  transition: opacity 0.3s ease;
  text-align: center;
  /* GPU 加速:5 条文案每 2.5s 淡入淡出一次,opacity 动画提升为合成层后
     不再触发主线程 reflow,文字切换丝滑 */
  will-change: opacity;
  transform: translateZ(0);
}

.subtitle {
  font-style: italic;
  color: var(--on-surface-variant, #514532);
  opacity: 0.7;
  margin-top: 8rpx;
  text-align: center;
}

.progress-track {
  width: 560rpx;
  height: 48rpx;
  background-color: var(--surface-container-low, #fff2e1);
  border-style: solid;
  border-width: 4rpx 3rpx 5rpx 4rpx;
  border-color: var(--outline, #837560);
  border-radius: 8rpx 20rpx 8rpx 24rpx / 24rpx 8rpx 20rpx 8rpx;
  padding: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: var(--primary-container, #ffb800);
  background-image: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 10rpx,
    rgba(255, 255, 255, 0.2) 10rpx,
    rgba(255, 255, 255, 0.2) 20rpx
  );
  transition: width 0.7s ease-out;
  border-radius: 4rpx;
  opacity: 0.8;
  /* GPU 加速:宽度动画提升为独立合成层,避免主线程 reflow */
  will-change: width;
  transform: translateZ(0);
}
