/* iconfont needed for component style isolation */
@import "/utils/iconfont.wxss";

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  background: linear-gradient(180deg, #7c5800 0%, #5c3f00 100%);
  color: #ffffff;
  display: flex;
  flex-direction: column;
  box-shadow: 4rpx 6rpx 0rpx 0rpx rgba(0, 0, 0, 0.12);
  border-bottom: 4rpx solid #514532;
}

.nav-bar.nav-bar--transparent {
  background: transparent;
  box-shadow: none;
  border-bottom: none;
}

.nav-bar.nav-bar--dark .nav-icon,
.nav-bar.nav-bar--dark .nav-title {
  color: #211b11;
  text-shadow: none;
}

.nav-bar.nav-bar--dark .menu-btn:active,
.nav-bar.nav-bar--dark .back-btn:active {
  background-color: rgba(0, 0, 0, 0.1);
}

.status-bar {
  width: 100%;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 0 32rpx;
  flex: 1;
}

.nav-bar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-bar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-title {
  font-weight: 600;
  letter-spacing: 1rpx;
  color: #faf3e0;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.15);
}

.nav-icon {
  font-size: 44rpx;
  color: #faf3e0;
}

.iconfont {
  font-family: "iconfont" !important;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.nav-icon:active {
  opacity: 0.7;
}

.menu-btn {
  padding: 8rpx;
}

.back-btn {
  padding: 8rpx;
}

.menu-btn:active,
.back-btn:active {
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
}
