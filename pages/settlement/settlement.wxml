<view class="settlement-page">
  <!-- Top Navigation Bar -->
  <navigation-bar
    title="游戏结束"
    type="back"
    customBack="{{true}}"
    bind:back="onNavBack"
    bind:heightchange="onNavHeightChange"
  />

  <view class="main-content" style="padding-top: {{navBarHeight}}px;">
    <!-- Hero Section -->
    <view class="hero">
      <view class="hero-title-wrap">
        <text class="hero-title text-display-lg">恭喜通关！🎉</text>
      </view>
      <text class="hero-subtitle text-body-lg">你已经征服了这片城市丛林！</text>
    </view>

    <!-- Stats Cards Section -->
    <view class="stats-cards">
      <view class="stat-card stat-card-left">
        <text class="stat-label text-mono-sm">完成圈数</text>
        <view class="stat-value-wrap">
          <text class="stat-value text-display-lg-mobile stat-value-secondary">{{lapsLabel}}</text>
          <text class="iconfont icon-trophy stat-icon-secondary"></text>
        </view>
      </view>
      <view class="stat-card stat-card-right">
        <text class="stat-label text-mono-sm">累计金币</text>
        <view class="stat-value-wrap">
          <text class="stat-value text-display-lg-mobile stat-value-primary">{{coins}}</text>
          <text class="iconfont icon-Dollar stat-icon-primary"></text>
        </view>
      </view>
    </view>

    <!-- Timeline Section -->
    <view class="timeline-section">
      <view class="timeline-decoration">
        <text class="iconfont icon-drag timeline-decoration-icon"></text>
      </view>
      <view class="timeline-header">
        <text class="iconfont icon-book timeline-header-icon"></text>
        <text class="timeline-header-text text-headline-md">探险日志</text>
      </view>
      <scroll-view class="timeline-scroll" scroll-x enable-flex>
        <view class="timeline-track">
          <view class="timeline-line"></view>
          <view class="timeline-nodes">
            <block wx:for="{{routeNodes}}" wx:key="id">
              <view class="timeline-node">
                <view class="node-icon-wrap node-{{item.tone}}">
                  <text class="iconfont {{item.icon}} node-icon"></text>
                </view>
                <view class="node-info">
                  <text class="node-label text-mono-sm">{{item.label}}</text>
                  <text class="node-score text-headline-sm">{{item.score}}</text>
                </view>
              </view>
            </block>
            <view class="timeline-node">
              <view class="node-icon-wrap node-goal">
                <text class="iconfont icon-trophy node-icon-goal"></text>
              </view>
              <view class="node-info">
                <text class="node-label text-mono-sm">GOAL</text>
                <text class="node-score text-headline-sm">{{goalScore}}</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- Footer Stats Chips -->
    <view class="footer-stats">
      <view class="footer-stat">
        <text class="footer-stat-label text-mono-sm">掷骰次数</text>
        <text class="footer-stat-value text-headline-sm">{{diceCount}}</text>
      </view>
      <view class="footer-stat-divider"></view>
      <view class="footer-stat">
        <text class="footer-stat-label text-mono-sm">行走步数</text>
        <text class="footer-stat-value text-headline-sm">{{steps}}</text>
      </view>
      <view class="footer-stat-divider"></view>
      <view class="footer-stat">
        <text class="footer-stat-label text-mono-sm">用时</text>
        <text class="footer-stat-value text-headline-sm">{{elapsed}}</text>
      </view>
    </view>

    <!-- Action Buttons -->
    <view class="action-buttons">
      <button class="btn-share text-headline-md" bindtap="onSharePoster">
        <text class="iconfont icon-share btn-share-icon"></text>
        <text class="btn-share-text text-headline-md">生成分享海报</text>
        <view class="btn-share-decoration">
          <text class="iconfont icon-book btn-share-decoration-icon"></text>
        </view>
      </button>
      <button class="btn-replay text-headline-md" bindtap="onReplay">
        <text class="iconfont icon-sync btn-replay-icon"></text>
        <text class="btn-replay-text text-headline-md">再玩一次</text>
      </button>
    </view>
  </view>

  <!-- Floating Stickers -->
  <view class="float-sticker float-sticker-tr">
    <text class="iconfont icon-book float-sticker-icon"></text>
  </view>
  <view class="float-sticker float-sticker-bl">
    <text class="iconfont icon-bulb float-sticker-icon-secondary"></text>
  </view>

  <!-- 海报分享弹窗 -->
  <poster-share
    visible="{{posterVisible}}"
    mapId="{{mapId}}"
    bind:close="onPosterClose"
  />
</view>
