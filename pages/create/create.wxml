<view class="create-page">
  <!-- WXS helper:判断 item.id 是否在 selectedTags 数组中(给 tag 芯片做 active 判断) -->
  <wxs module="m">
  module.exports = {
    includes: function(arr, item) {
      if (!arr) return false;
      for (var i = 0; i < arr.length; i++) {
        if (arr[i] === item) return true;
      }
      return false;
    }
  };
  </wxs>

  <!-- Top App Bar -->
  <navigation-bar
    title="创建地图"
    type="back"
    bind:heightchange="onNavHeightChange"
  />
  <!-- Main Content -->
  <scroll-view class="main-content" scroll-y style="margin-top: {{navBarHeight}}px;">
    <!-- Step Indicator -->
    <view class="step-indicator">
      <view class="step-item">
        <view class="step-circle {{step >= 1 ? 'active' : 'pending'}}">
          <text class="iconfont step-icon icon-check" wx:if="{{step > 1}}"></text>
          <text class="step-number text-mono" wx:else>1</text>
        </view>
        <text class="step-label text-mono-sm {{step >= 1 ? '' : 'pending'}}">定位</text>
      </view>
      <view class="step-line {{step > 1 ? 'active' : ''}}"></view>
      <view class="step-item">
        <view class="step-circle {{step >= 2 ? 'active' : 'pending'}}">
          <text class="iconfont step-icon icon-check" wx:if="{{step > 2}}"></text>
          <text class="step-number text-mono" wx:else>2</text>
        </view>
        <text class="step-label text-mono-sm {{step >= 2 ? '' : 'pending'}}">范围</text>
      </view>
      <view class="step-line {{step > 2 ? 'active' : ''}}"></view>
      <view class="step-item">
        <view class="step-circle {{step >= 3 ? 'active' : 'pending'}}">
          <text class="iconfont step-icon icon-check" wx:if="{{step > 3}}"></text>
          <text class="step-number text-mono" wx:else>3</text>
        </view>
        <text class="step-label text-mono-sm {{step >= 3 ? '' : 'pending'}}">选项</text>
      </view>
      <view class="step-line {{step > 3 ? 'active' : ''}}"></view>
      <view class="step-item">
        <view class="step-circle {{step >= 4 ? 'active' : 'pending'}}">
          <text class="step-number text-mono">4</text>
        </view>
        <text class="step-label text-mono-sm {{step >= 4 ? '' : 'pending'}}">生成</text>
      </view>
    </view>

    <!-- Map Preview (Step 1 & 2) — 微信原生 <map> + markers,不再是静态背景图 -->
    <view class="map-preview" wx:if="{{step <= 2}}">
      <map
        id="createMap"
        class="create-native-map"
        latitude="{{location ? location.latitude : mapCenterLat}}"
        longitude="{{location ? location.longitude : mapCenterLng}}"
        markers="{{mapMarkers}}"
        scale="{{mapScale}}"
        show-location="{{true}}"
        enable-zoom="{{true}}"
        enable-scroll="{{true}}"
        enable-rotate="{{false}}"
        subkey="{{amapSubkey}}"
      ></map>
      <!-- 范围圆 — 叠加在地图上,直观显示探索半径 -->
      <view class="range-circle-container">
        <view class="range-circle {{rangeSizeClass}}">
          <view class="marker-pulse">
            <text class="iconfont location-icon icon-plus-circle"></text>
          </view>
        </view>
      </view>
      <view class="search-hint" bindtap="onSearchHintTap">
        <text class="iconfont search-hint-icon icon-search"></text>
        <text class="search-hint-text text-mono-sm">搜索地点，例如：王府井</text>
        <text class="iconfont search-hint-arrow icon-right"></text>
      </view>
    </view>

    <!-- Step 1: Location -->
    <view class="step-content" wx:if="{{step === 1}}">
      <view class="location-box">
        <text class="location-text text-body-md" wx:if="{{location}}">当前位置：{{location.address}}</text>
        <text class="location-text text-body-md" wx:else>正在获取位置...</text>
        <button class="btn-primary text-body-md" bindtap="getLocation" disabled="{{gettingLocation}}">
          {{gettingLocation ? '获取中...' : '重新定位'}}
        </button>
      </view>
    </view>

    <!-- Step 2: Range Selection -->
    <view class="selection-ui" wx:if="{{step === 2}}">
      <text class="section-title text-headline-sm">设置探索范围</text>
      <view class="range-buttons">
        <view class="range-btn" data-selected="{{selectedRange === 0}}" bindtap="onRangeSelect" data-index="0">
          <text class="range-btn-text text-mono">500米</text>
          <text class="range-btn-subtext text-mono-sm">小型</text>
        </view>
        <view class="range-btn" data-selected="{{selectedRange === 1}}" bindtap="onRangeSelect" data-index="1">
          <text class="range-btn-text text-mono">1公里</text>
          <text class="range-btn-subtext text-mono-sm">标准</text>
        </view>
        <view class="range-btn" data-selected="{{selectedRange === 2}}" bindtap="onRangeSelect" data-index="2">
          <text class="range-btn-text text-mono">1.5公里</text>
          <text class="range-btn-subtext text-mono-sm">大型</text>
        </view>
      </view>
      <text class="range-description text-body-sm">范围越大包含的地块越多，但探索所需的体力也越多。</text>

      <!-- 想去的地方(偏好 tag 芯片) -->
      <view class="tag-chips-section">
        <view class="tag-chips-header">
          <text class="tag-chips-title">想去的地方</text>
          <view class="tag-chips-randomize" bindtap="onRandomizeTags">
            <text class="iconfont icon-sync"></text>
            <text class="text-mono-sm">换一组</text>
          </view>
        </view>
        <view class="tag-chips-row">
          <view
            wx:for="{{tagGroups}}"
            wx:key="id"
            class="tag-chip {{m.includes(selectedTags, item.id) ? 'active' : ''}}"
            bindtap="onTagToggle"
            data-id="{{item.id}}"
          >
            <text class="tag-chip-text text-mono-sm">{{item.name}}</text>
          </view>
        </view>
      </view>

      <!-- POI 不足提示:仅当 insufficientPoiError 非空时显示 -->
      <view wx:if="{{insufficientPoiError}}" class="poi-error">
        <text class="poi-error-text">
          搜索到 {{insufficientPoiError.found}} 个 POI,不够 {{insufficientPoiError.needed}} 个格子
        </text>
        <view class="poi-error-actions">
          <button class="poi-error-btn" bindtap="onPoiErrorRelocate">重新定位</button>
          <button class="poi-error-btn" bindtap="onPoiErrorUseExisting">用现有数额</button>
          <button class="poi-error-btn" bindtap="onPoiErrorExpandRange">扩大范围</button>
        </view>
      </view>
    </view>

    <!-- Step 3: Config Options -->
    <view class="step-content" wx:if="{{step === 3}}">
      <view class="config-section">
        <text class="config-label text-mono-sm">地图名称</text>
        <input class="config-input" placeholder="默认：我的探索-日期" value="{{mapName}}" bindinput="onMapNameInput"/>
      </view>

      <view class="config-section">
        <text class="config-label text-mono-sm">地图想法(可选)</text>
        <textarea
          class="map-idea-input"
          placeholder="例:想逛有历史感的老店,顺便去咖啡馆坐坐"
          maxlength="200"
          value="{{mapIdea}}"
          bindinput="onMapIdeaInput"
          auto-height
        />
        <text class="map-idea-counter text-mono-sm">{{200 - mapIdea.length}} 字可写</text>
      </view>

      <view class="config-section">
        <text class="config-label text-mono-sm">格子数量</text>
        <view class="grid-count-options">
          <view class="grid-option {{gridCount === 15 ? 'selected' : ''}}" bindtap="selectGridCount" data-count="15">15</view>
          <view class="grid-option {{gridCount === 20 ? 'selected' : ''}}" bindtap="selectGridCount" data-count="20">20</view>
          <view class="grid-option {{gridCount === 25 ? 'selected' : ''}}" bindtap="selectGridCount" data-count="25">25</view>
          <view class="grid-option {{gridCount === 30 ? 'selected' : ''}}" bindtap="selectGridCount" data-count="30">30</view>
        </view>
      </view>

      <view class="config-section">
        <text class="config-label text-mono-sm">允许重复打卡</text>
        <switch checked="{{allowRepeatCheckin}}" bindchange="onAllowRepeatChange" color="var(--primary)"/>
      </view>

      <view class="config-section">
        <text class="config-label text-mono-sm">起始金币</text>
        <input class="config-input" type="number" value="{{initialGold}}" bindinput="onInitialGoldInput"/>
      </view>

      <view class="config-section">
        <text class="config-label text-mono-sm">每圈奖励</text>
        <input class="config-input" type="number" value="{{lapRewardGold}}" bindinput="onLapRewardInput"/>
      </view>
    </view>

    <!-- Step 4: Generating / Preview -->
    <view class="step-content" wx:if="{{step === 4}}">
      <view class="generating" wx:if="{{generating}}">
        <drawing-progress />
        <text class="generating-subtext text-body-sm">大模型深度解析中，请尽量保持应用在前台</text>
        <text class="generating-subtext text-body-sm">请稍候，这可能需要几分钟</text>
      </view>
      <view class="preview" wx:else>
        <text class="preview-title text-headline-sm">{{generatedMap.name}}</text>
        <text class="preview-info text-body-sm">共 {{generatedMap.grids.length}} 个格子</text>
        <!-- POI 简略列表 — 让玩家看到地图实际内容,不只是格子数 -->
        <view class="preview-poi-list">
          <view
            wx:for="{{generatedMap.grids}}"
            wx:key="index"
            class="preview-poi-row {{item.chanceCards && item.chanceCards.length > 0 ? 'has-chance' : ''}}"
          >
            <text class="preview-poi-index text-mono">{{item.index + 1}}</text>
            <view class="preview-poi-info">
              <text class="preview-poi-name text-body-md" wx:if="{{item.poi}}">{{item.poi.name}}</text>
              <text class="preview-poi-name text-body-md preview-poi-empty" wx:else>未知道点</text>
              <text class="preview-poi-type text-mono-sm" wx:if="{{item.poi && item.poi.type}}">{{item.poi.type}}</text>
            </view>
            <text class="preview-poi-chance" wx:if="{{item.chanceCards && item.chanceCards.length > 0}}">机会格</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Navigation Buttons -->
  <view class="nav-buttons" wx:if="{{step < 4}}">
    <view class="btn-back text-headline-sm" bindtap="prevStep" wx:if="{{step > 1 && !generating && !poiLoading}}">返回</view>
    <view class="btn-next text-headline-sm" bindtap="nextStep" wx:if="{{step < 4 && !generating && !poiLoading}}">
      <text>下一步</text>
      <text class="iconfont btn-next-icon icon-right"></text>
    </view>
    <view class="btn-next text-headline-sm btn-loading" wx:if="{{step < 4 && poiLoading}}">
      <text>加载中...</text>
    </view>
  </view>

  <!-- Step 4 Navigation Buttons -->
  <view class="nav-buttons-step4" wx:if="{{step === 4 && !generating}}">
    <view class="nav-buttons-row">
      <view class="btn-back-small text-body-md" bindtap="prevStep">返回</view>
      <view class="btn-back-small text-body-md" bindtap="regenerateMap">重新生成</view>
    </view>
    <view class="btn-save text-headline-sm" bindtap="saveMap">
      <text>保存地图</text>
    </view>
  </view>

  <!-- Atmosphere Effects -->
  <view class="atmosphere"></view>
</view>