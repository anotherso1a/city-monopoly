/* createtest 页面样式 - 基于 design/create.html 转换 */

page {
  box-sizing: border-box;
  overflow-x: hidden;
  --primary: #7c5800;
  --primary-container: #ffb800;
  --on-primary: #ffffff;
  --on-primary-container: #6b4c00;
  --secondary: #b71032;
  --surface: #fff8f3;
  --surface-container: #f9ecdb;
  --surface-container-low: #fff2e1;
  --surface-container-lowest: #ffffff;
  --surface-container-high: #f3e6d6;
  --surface-container-highest: #ede1d0;
  --on-surface: #211b11;
  --on-surface-variant: #514532;
  --outline: #837560;
  --outline-variant: #d5c4ab;
  --tertiary: #00658d;
  --background: #fff8f3;
  --shadow-color: rgba(0, 0, 0, 0.1);
}

.create-page {
  min-height: 100vh;
  background-color: var(--background);
  display: flex;
  flex-direction: column;
}

/* Top App Bar */
.top-app-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  background-color: var(--primary);
  color: var(--on-primary);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  box-shadow: 4rpx 4rpx 0px 0px var(--shadow-color);
  border-bottom: 4rpx solid var(--on-surface-variant);
}

.top-app-bar-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.back-btn {
  padding: 8rpx;
}

.back-btn:active {
  transform: translateY(2rpx);
}

/* Main Content */
.main-content {
  box-sizing: border-box;
  flex: 1;
  margin-bottom: 200rpx;
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  overflow-y: auto;
}

/* Step Indicator */
.step-indicator {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 32rpx 16rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.step-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--primary);
  box-shadow: 4rpx 4rpx 0px 0px rgba(81, 69, 50, 0.15);
}

.step-circle.active {
  background-color: var(--primary-container);
}

.step-circle.pending {
  background-color: var(--surface-container-highest);
  border-style: dashed;
  border-color: var(--outline-variant);
}

.step-icon {
  font-size: 36rpx;
  color: var(--on-primary-container);
}

.step-number {
  font-weight: 700;
  color: var(--on-surface-variant);
}

.step-label {
  font-weight: 700;
  color: var(--primary);
}

.step-label.pending {
  color: var(--on-surface-variant);
  opacity: 0.6;
}

.step-line {
  height: 4rpx;
  background-color: var(--outline-variant);
  flex: 1;
  margin-top: 40rpx;
}

/* Map Preview */
.map-preview {
  position: relative;
  box-sizing: border-box;
  width: 100%;
  aspect-ratio: 1;
  border-radius: 24rpx;
  overflow: hidden;
  border: 4rpx solid var(--primary);
  background-color: var(--surface-container);
  box-shadow: 4rpx 4rpx 0px 0px rgba(81, 69, 50, 0.15);
}

.create-native-map {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.map-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: grayscale(0.8);
  opacity: 0.8;
  background-size: cover;
  background-position: center;
}

.map-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(124, 88, 0, 0.1);
  mix-blend-mode: multiply;
}

.range-circle-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  pointer-events: none;  /* 让点击穿透到下方 <map> */
}

.range-circle {
  width: 384rpx;
  height: 384rpx;
  border-radius: 50%;
  border: 8rpx dashed var(--primary-container);
  background-color: rgba(255, 184, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.5s ease-in-out;
}

.range-circle.size-small {
  width: 256rpx;
  height: 256rpx;
}

.range-circle.size-large {
  width: 512rpx;
  height: 512rpx;
}

.marker-pulse {
  position: relative;
}

.marker-pulse::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: rgba(0, 101, 141, 0.4);
  animation: pulse-blue 1.5s infinite ease-in-out;
  /* GPU 加速:提升为独立合成层,避免 pulse 动画在主线程重绘
     导致地图上叠加层卡顿。will-change + translateZ(0) 双保险 */
  will-change: transform, opacity;
  transform: translate(-50%, -50%) translateZ(0);
}

@keyframes pulse-blue {
  0% { transform: translate(-50%, -50%) translateZ(0) scale(0.9); opacity: 0.8; }
  50% { transform: translate(-50%, -50%) translateZ(0) scale(1.1); opacity: 1; }
  100% { transform: translate(-50%, -50%) translateZ(0) scale(0.9); opacity: 0.8; }
}

.location-icon {
  font-size: 72rpx;
  color: var(--tertiary);
  position: relative;
  z-index: 20;
}

.search-hint {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  z-index: 3;
  background-color: rgba(255, 255, 255, 0.95);
  padding: 16rpx 24rpx;
  border-radius: 9999rpx;
  border: 4rpx solid var(--outline);
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 4rpx 4rpx 0px 0px rgba(81, 69, 50, 0.15);
  transition: transform 0.1s ease, box-shadow 0.1s ease;
}

.search-hint:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 0 0 0 0 rgba(81, 69, 50, 0.15);
}

.search-hint-arrow {
  font-size: 28rpx;
  color: var(--on-surface-variant);
}

.search-hint-icon {
  font-size: 32rpx;
  color: var(--on-surface-variant);
}

.search-hint-text {
  font-weight: 700;
  color: var(--on-surface-variant);
}

/* Selection UI */
.selection-ui {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.section-title {
  font-weight: 700;
  text-align: center;
  padding: 0 32rpx;
}

.range-buttons {
  display: flex;
  justify-content: center;
  gap: 32rpx;
}

.range-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  border-radius: 24rpx;
  border: 4rpx solid var(--outline);
  background-color: var(--surface);
}

.range-btn[data-selected="true"] {
  border: 4rpx solid var(--primary) !important;
  background-color: var(--primary-container) !important;
  box-shadow: 4rpx 4rpx 0px 0px rgba(81, 69, 50, 0.15);
}

.range-btn[data-selected="true"] .range-btn-text {
  color: var(--on-primary-container) !important;
}

.range-btn[data-selected="true"] .range-btn-subtext {
  color: var(--on-primary-container) !important;
  opacity: 1 !important;
}

.range-btn-text {
  font-weight: 700;
  color: var(--on-surface-variant);
}

.range-btn-subtext {
  font-weight: 700;
  color: var(--on-surface-variant);
  opacity: 0.6;
  margin-top: 8rpx;
}

.range-description {
  text-align: center;
  color: var(--on-surface-variant);
  padding: 0 64rpx;
}

/* Step Content (Step 1, 3, 4) */
.step-content {
  background-color: var(--surface-container-lowest);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 4rpx solid var(--outline-variant);
}

/* Step 1: Location */
.location-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  gap: 24rpx;
}

.location-text {
  color: var(--on-surface);
  text-align: center;
}

/* 重新定位主按钮 (Step 1) — 本地化, 不依赖 app.wxss 已删除的全局 .btn-primary */
.btn-primary {
  min-width: 240rpx;
  padding: 24rpx 48rpx;
  background-color: var(--primary);
  color: var(--on-primary);
  font-weight: 700;
  border: 4rpx solid var(--on-surface-variant);
  border-radius: 24rpx;
  box-shadow: 4rpx 4rpx 0px 0px var(--shadow-color);
  text-align: center;
  transition: all;
}

.btn-primary:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: none;
}

.btn-primary[disabled] {
  opacity: 0.5;
  background-color: var(--outline);
}

/* Step 3: Config */
.config-section {
  margin-bottom: 32rpx;
}

.config-label {
  display: block;
  color: var(--on-surface-variant);
  margin-bottom: 12rpx;
  font-weight: 700;
}

.config-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 4rpx solid var(--outline);
  border-radius: 16rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  color: var(--on-surface);
  background-color: var(--surface-container-lowest);
}

.config-input:focus {
  border-color: var(--primary);
}

.grid-count-options {
  display: flex;
  gap: 16rpx;
}

.grid-option {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--outline);
  border-radius: 16rpx;
  font-size: 32rpx;
  color: var(--on-surface-variant);
  background-color: var(--surface-container-lowest);
}

.grid-option.selected {
  border-color: var(--primary);
  background-color: var(--primary-container);
  color: var(--on-primary-container);
  font-weight: 700;
}

/* Step 4: Generating / Preview */
.generating {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 32rpx;
}

.generating-subtext {
  color: var(--on-surface-variant);
}

.preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
}

.preview-title {
  font-weight: 700;
  color: var(--on-surface);
  margin-bottom: 16rpx;
}

.preview-info {
  color: var(--on-surface-variant);
  margin-bottom: 24rpx;
}

/* POI 简略列表 — 让玩家在保存前看到地图实际包含哪些地点 */
.preview-poi-list {
  width: 100%;
  max-height: 700rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  overflow-y: auto;
  padding: 4rpx;
  box-sizing: border-box;
}

.preview-poi-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background-color: var(--surface-container-low);
  border: 2rpx solid var(--outline-variant);
  border-radius: 16rpx;
  text-align: left;
}

.preview-poi-row.has-chance {
  background-color: #fff4e5;
  border-color: #ffd591;
}

.preview-poi-index {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: var(--primary-container);
  color: var(--on-primary-container);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.preview-poi-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.preview-poi-name {
  font-weight: 700;
  color: var(--on-surface);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-poi-empty {
  opacity: 0.5;
  font-style: italic;
}

.preview-poi-type {
  color: var(--on-surface-variant);
  opacity: 0.7;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-poi-chance {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  background-color: #d46b08;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 8rpx;
}

/* Navigation Buttons */
.nav-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background-color: rgba(255, 248, 243, 0.8);
  backdrop-filter: blur(20rpx);
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  z-index: 40;
}

.btn-back {
  flex: 1;
  padding: 32rpx;
  border: 4rpx solid var(--outline);
  border-radius: 24rpx;
  font-weight: 700;
  color: var(--on-surface-variant);
  text-align: center;
  transition: all;
}

.btn-back:active {
  transform: translateY(2rpx) translateX(2rpx);
}

.btn-secondary {
  flex: 1;
  padding: 32rpx;
  border: 4rpx solid var(--outline);
  border-radius: 24rpx;
  font-weight: 700;
  color: var(--on-surface-variant);
  text-align: center;
  transition: all;
}

.btn-secondary:active {
  transform: translateY(2rpx) translateX(2rpx);
}

.btn-next {
  flex: 2;
  padding: 32rpx;
  background-color: var(--primary);
  color: var(--on-primary);
  border: 4rpx solid var(--primary);
  border-radius: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 4rpx 4rpx 0px 0px rgba(0, 0, 0, 1);
  transition: all;
}

.btn-next:active {
  transform: translateY(2rpx) translateX(2rpx);
  box-shadow: none;
}

.btn-next-icon {
  font-size: 36rpx;
}

/* Atmosphere Effects */
.atmosphere {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  opacity: 0.03;
  mix-blend-mode: multiply;
  background-color: var(--background);
  background-image: radial-gradient(#d5c4ab 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  z-index: 100;
}

/* Step 4 Navigation Buttons */
.nav-buttons-step4 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background-color: rgba(255, 248, 243, 0.8);
  backdrop-filter: blur(20rpx);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 40;
}

.nav-buttons-row {
  display: flex;
  gap: 16rpx;
}

.btn-back-small {
  flex: 1;
  padding: 20rpx;
  border: 4rpx solid var(--outline);
  border-radius: 24rpx;
  font-weight: 700;
  color: var(--on-surface-variant);
  text-align: center;
  transition: all;
}

.btn-back-small:active {
  transform: translateY(2rpx) translateX(2rpx);
}

.btn-save {
  padding: 32rpx;
  background-color: var(--primary);
  color: var(--on-primary);
  border: 4rpx solid var(--primary);
  border-radius: 24rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 4rpx 4rpx 0px 0px rgba(0, 0, 0, 1);
  transition: all;
}

.btn-save:active {
  transform: translateY(2rpx) translateX(2rpx);
  box-shadow: none;
}

.poi-error {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #fff4e5;
  border-radius: 12rpx;
  border: 2rpx solid #ffd591;
}
.poi-error-text {
  display: block;
  font-size: 28rpx;
  color: #d46b08;
  margin-bottom: 16rpx;
}
.poi-error-actions {
  display: flex;
  gap: 16rpx;
}
.poi-error-btn {
  flex: 1;
  font-size: 26rpx;
  background: #fff;
  color: #d46b08;
  border: 2rpx solid #ffd591;
}

/* Step 2: Tag 偏好芯片 */
.tag-chips-section {
  margin-top: 16rpx;
  padding: 24rpx;
  background-color: var(--surface-container-low);
  border: 4rpx dashed var(--outline-variant);
  border-radius: 16rpx;
}

.tag-chips-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.tag-chips-title {
  font-weight: 700;
  color: var(--on-surface-variant);
  font-size: 30rpx;
}

.tag-chips-randomize {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 9999rpx;
  border: 2rpx solid var(--outline);
  background-color: var(--surface-container-lowest);
  color: var(--on-surface-variant);
  font-weight: 700;
  transition: all 0.1s ease;
}
.tag-chips-randomize:active {
  transform: translate(2rpx, 2rpx);
  background-color: var(--surface-container);
}
.tag-chips-randomize .iconfont {
  font-size: 28rpx;
}

.tag-chips-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  border-radius: 9999rpx;
  border: 4rpx solid var(--outline);
  background-color: var(--surface-container-lowest);
  box-shadow: 2rpx 2rpx 0px 0px rgba(81, 69, 50, 0.1);
  transition: all 0.1s ease;
}
.tag-chip:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: none;
}
.tag-chip.active {
  border-color: var(--primary);
  background-color: var(--primary-container);
  box-shadow: 2rpx 2rpx 0px 0px var(--on-surface-variant);
}
.tag-chip-text {
  font-weight: 700;
  color: var(--on-surface-variant);
}
.tag-chip.active .tag-chip-text {
  color: var(--on-primary-container);
}

/* Step 3: 玩家偏好输入框 */
.map-idea-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  border: 4rpx solid var(--outline);
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  color: var(--on-surface);
  background-color: var(--surface-container-lowest);
  line-height: 1.5;
}
.map-idea-input:focus {
  border-color: var(--primary);
}

.map-idea-counter {
  display: block;
  text-align: right;
  margin-top: 8rpx;
  color: var(--on-surface-variant);
  opacity: 0.7;
  font-size: 24rpx;
}