/* search 页面 - 基于 design/search.html 转换 */

page {
  box-sizing: border-box;
  overflow-x: hidden;
  --primary: #7c5800;
  --primary-container: #ffb800;
  --on-primary: #ffffff;
  --on-primary-container: #6b4c00;
  --secondary: #b71032;
  --background: #fff8f3;
  --surface-container-low: #fff2e1;
  --surface-container-lowest: #ffffff;
  --on-surface: #211b11;
  --on-surface-variant: #514532;
  --outline: #837560;
  --outline-variant: #d5c4ab;
  --shadow-color: rgba(54, 47, 36, 0.1);
}

.search-page {
  min-height: 100vh;
  background-color: var(--background);
  background-image: radial-gradient(#d5c4ab 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  color: var(--on-surface);
}

.main-content {
  padding: 0 48rpx 48rpx;
}

/* Search Bar */
.search-bar-wrapper {
  position: relative;
  margin-top: 32rpx;
  margin-bottom: 32rpx;
}

.tape-deco {
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%) rotate(2deg);
  width: 128rpx;
  height: 24rpx;
  background-color: var(--primary-container);
  opacity: 0.4;
  pointer-events: none;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 0 32rpx;
  height: 112rpx;
  background-color: var(--surface-container-lowest);
  border: 4rpx solid var(--primary-container);
  border-radius: 8rpx 16rpx 6rpx 12rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 8rpx var(--shadow-color);
}

.search-bar.focused {
  box-shadow: 0 0 0 4rpx var(--primary);
}

.search-icon {
  font-size: 36rpx;
  color: var(--outline);
}

.search-input {
  flex: 1;
  height: 100%;
  color: var(--on-surface);
  background: transparent;
}

.search-clear {
  padding: 8rpx;
}

.clear-icon {
  font-size: 40rpx;
  color: var(--secondary);
  line-height: 1;
}

.search-go {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  height: 64rpx;
  background-color: var(--primary-container);
  color: var(--on-primary-container);
  border-radius: 8rpx 16rpx 6rpx 12rpx;
  font-weight: 700;
  flex-shrink: 0;
  transition: transform 0.1s ease;
}

.search-go:active {
  transform: scale(0.96);
  background-color: var(--primary);
  color: var(--on-primary);
}

/* Map Pick Entry (备选: 微信原生地图选点) */
.map-pick-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 32rpx;
  background-color: var(--primary-container);
  border: 4rpx solid var(--on-surface);
  border-radius: 16rpx;
  box-shadow: 4rpx 4rpx 0px 0px var(--on-surface);
  transition: transform 0.1s ease, box-shadow 0.1s ease;
}

.map-pick-row:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 0 0 0 0 var(--on-surface);
}

.map-pick-icon {
  font-size: 48rpx;
  color: var(--on-primary-container);
}

.map-pick-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.map-pick-title {
  font-weight: 700;
  color: var(--on-primary-container);
}

.map-pick-subtitle {
  color: var(--on-surface-variant);
}

.map-pick-arrow {
  font-size: 36rpx;
  color: var(--on-primary-container);
}

/* Results Section */
.results-section {
  padding-bottom: 96rpx;
}

.results-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 0 8rpx;
  margin-bottom: 24rpx;
}

.results-count {
  font-weight: 700;
  color: var(--outline);
  text-transform: uppercase;
  letter-spacing: 0.2em;
}

.results-status {
  color: var(--on-surface-variant);
}

.empty-hint {
  padding: 96rpx 32rpx;
  text-align: center;
}

.empty-hint-text {
  color: var(--outline);
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.result-card {
  background-color: var(--surface-container-lowest);
  border: 4rpx solid var(--outline);
  border-radius: 8rpx 20rpx 6rpx 12rpx;
  box-shadow: 8rpx 8rpx 0px 0px var(--shadow-color);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  transition: transform 0.1s ease, box-shadow 0.1s ease;
}

.result-card:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 2rpx 2rpx 0px 0px var(--shadow-color);
}

.result-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.result-name {
  font-weight: 700;
  color: var(--on-surface);
  flex: 1;
}

.result-tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.result-tag {
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 4rpx 8rpx 4rpx 6rpx;
  border: 2rpx solid;
  white-space: nowrap;
}

.tag-distance {
  color: var(--on-surface-variant);
  background-color: var(--surface-container-low);
  border-color: var(--outline);
}

.result-desc {
  color: var(--on-surface-variant);
  margin-top: 4rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.result-type {
  display: block;
  color: var(--outline);
  margin-top: 4rpx;
}
