/* ============ Global styles for City Monopoly ============ */
@import "utils/iconfont.wxss";

page {
  box-sizing: border-box;
  overflow-x: hidden;
  width: 750rpx;
  background-color: #f7eed2;
  color: #1f1c0b;
  font-family: "Source Serif 4", "Noto Serif SC", -apple-system, BlinkMacSystemFont, serif;
}

/* ============ Text scale (字号标尺) ============ */
.text-display-lg {
  font-size: 96rpx;
  line-height: 112rpx;
  font-weight: 700;
  font-family: "Libre Caslon Text", "Source Serif 4", "Noto Serif SC", serif;
  letter-spacing: -0.02em;
}

.text-display-lg-mobile {
  font-size: 64rpx;
  line-height: 80rpx;
  font-weight: 700;
  font-family: "Libre Caslon Text", "Source Serif 4", "Noto Serif SC", serif;
  letter-spacing: -0.02em;
}

.text-headline-md {
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 600;
  font-family: "Libre Caslon Text", "Source Serif 4", "Noto Serif SC", serif;
}

.text-headline-sm {
  font-size: 32rpx;
  line-height: 40rpx;
  font-weight: 700;
  font-family: "Source Serif 4", "Noto Serif SC", serif;
}

.text-body-lg {
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: 400;
  font-family: "Source Serif 4", "Noto Serif SC", serif;
}

.text-body-md {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 400;
  font-family: "Source Serif 4", "Noto Serif SC", serif;
}

.text-body-sm {
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 400;
  font-family: "Source Serif 4", "Noto Serif SC", serif;
}

.text-mono {
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 700;
  font-family: "Courier Prime", "Courier New", monospace;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.text-mono-sm {
  font-size: 20rpx;
  line-height: 28rpx;
  font-weight: 600;
  font-family: "Courier Prime", "Courier New", monospace;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

/* ============ Paper utility classes (纸面工具类) ============ */
.sketch-border-sm {
  border: 3rpx solid #837560;
  border-radius: 24rpx 8rpx 28rpx 10rpx / 8rpx 28rpx 10rpx 24rpx;
}

.sketch-border {
  border: 4rpx solid #837560;
  border-radius: 510rpx 30rpx 450rpx 30rpx / 30rpx 450rpx 30rpx 510rpx;
}

.ink-divider-sm {
  height: 2rpx;
  background-color: rgba(131, 117, 96, 0.2);
  margin: 16rpx 0;
}

.ink-divider {
  height: 4rpx;
  background: radial-gradient(circle, #837560 0%, transparent 100%);
  opacity: 0.4;
  position: relative;
  margin: 24rpx 0;
}

.ink-divider::before,
.ink-divider::after {
  content: "✦";
  position: absolute;
  top: -10rpx;
  color: #837560;
  font-size: 24rpx;
}

.ink-divider::before { left: 10%; }
.ink-divider::after  { right: 10%; }

.soft-shadow {
  box-shadow: 0 4rpx 12rpx rgba(131, 117, 96, 0.15);
}

.paper-texture {
  background-color: #fff9ed;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(124, 88, 0, 0.04) 0%, transparent 40%),
    radial-gradient(circle at 80% 70%, rgba(124, 88, 0, 0.03) 0%, transparent 40%),
    repeating-linear-gradient(0deg, transparent, transparent 4rpx, rgba(131, 117, 96, 0.015) 4rpx, rgba(131, 117, 96, 0.015) 5rpx);
}

/* ============ Common animations ============ */
@keyframes ink-fade {
  from { opacity: 0; transform: translateY(10rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.animate-warm {
  animation: ink-fade 0.8s ease-out forwards;
}
